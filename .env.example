# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
RESEND_API_KEY=your_resend_api_key_here

# Gmail (fallback sender)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Your Profile — basics
MY_NAME=Your Full Name
MY_TARGET_ROLE=Software Engineer
MY_EXPERIENCE_YEARS=3
MY_KEY_SKILL_1=Python
MY_KEY_SKILL_2=Data Analysis
MY_KEY_SKILL_3=Machine Learning
MY_CURRENT_PROJECT=an AI-powered inventory management system for small retailers

# Your Profile — links
MY_LINKEDIN_URL=https://linkedin.com/in/yourprofile
MY_GITHUB_URL=https://github.com/yourusername
MY_PORTFOLIO_URL=https://your-portfolio-link.com
MY_RESUME_URL=https://your-resume-link.com
MY_PHONE=+91-XXXXXXXXXX
MY_EMAIL_DISPLAY=

# Your Profile — email body text
# MY_INTRO is used verbatim as the "who I am" paragraph (PART 3).
# MY_LOOKING_FOR is dropped into the role-search line (PART 4).
MY_INTRO=I'm a [your positioning here — recent grad / X years experience / etc.] with hands-on experience in [areas].
MY_LOOKING_FOR=Software Engineer, Data Scientist, or AI/ML Engineer
